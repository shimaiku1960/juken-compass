// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  date        DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Profile {
  id        String     @id
  nickname  String
  createdAt DateTime   @default(now())
  studyLogs StudyLog[]
  finalGoals FinalGoal[] 
  subjects   Subject[]
}



model StudyLog {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  minutes   Int
  category  String
  memo      String?
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
}

model FinalGoal {                                                                                                                                          
  id        Int      @id @default(autoincrement())                                                                                                         
  title     String                                                                                                                                         
  examDate  DateTime                                                                                                                                       
  createdAt DateTime @default(now())                                                                                                                       
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])                                                                                      
                                                                                                                                                           
  subjectWeights SubjectWeight[]                                                                                                                           
}

model Subject {                                                                                                                                            
  id        Int      @id @default(autoincrement())                                                                                                           
  name      String                                                                                                                                           
  createdAt DateTime @default(now())                                                                                                                         
  profileId String                                                                                                                                           
  profile   Profile  @relation(fields: [profileId], references: [id])                                                                                      

  subjectWeights    SubjectWeight[]
  intermediateGoals IntermediateGoal[]
}  


model SubjectWeight {
  id          Int       @id @default(autoincrement())
  weight      Int
  finalGoalId Int
  finalGoal   FinalGoal @relation(fields: [finalGoalId], references: [id], onDelete: Cascade)
  subjectId   Int
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([finalGoalId, subjectId])
}

model IntermediateGoal {
  id        Int      @id @default(autoincrement())
  title     String
  deadline  DateTime
  createdAt DateTime @default(now())
  subjectId Int
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  weeklyGoals WeeklyGoal[]
}

model WeeklyGoal {
  id                 Int              @id @default(autoincrement())
  title              String
  weekStart          DateTime
  createdAt          DateTime         @default(now())
  intermediateGoalId Int
  intermediateGoal   IntermediateGoal @relation(fields: [intermediateGoalId], references: [id], onDelete: Cascade)

  dailyGoals DailyGoal[]
}

model DailyGoal {
  id           Int        @id @default(autoincrement())
  title        String
  completed    Boolean    @default(false)
  date         DateTime
  createdAt    DateTime   @default(now())
  weeklyGoalId Int
  weeklyGoal   WeeklyGoal @relation(fields: [weeklyGoalId], references: [id], onDelete: Cascade)
}     
                 


